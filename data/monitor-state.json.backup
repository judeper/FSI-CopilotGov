        "2026-07783": "sha256:565ee902039cf2e44e96d0525ebaf4cf865fb003e6c46f41aad866ddb832b852",
        "2026-07782": "sha256:cd8397843a9509cfaac5dbce9f417f56a6ca7c10b477684003667bbf58c61c55",
