    "graph": {
      "filename": "graph.json",
      "collector": "Collect-Graph.ps1",
      "description": "Microsoft Graph / Entra ID: Conditional Access, security groups, privileged roles, service principals, tenant settings."
    },
    "purview": {
      "filename": "purview.json",
      "collector": "Collect-Purview.ps1",
      "description": "Microsoft Purview: audit config, DLP policies, retention, communication compliance, eDiscovery, insider risk, DSPM, sensitivity labels."
    },
    "sharepoint": {
      "filename": "sharepoint.json",
      "collector": "Collect-SharePoint.ps1",
      "description": "SharePoint Online: site inventory, sharing settings, retention labels, guest access, item-level permissions."
    },
    "sentinel": {
      "filename": "sentinel.json",
      "collector": "Collect-Sentinel.ps1",
      "description": "Microsoft Sentinel: workspace config, data connectors, KQL audit queries for CopilotInteraction events."
    }
  },
