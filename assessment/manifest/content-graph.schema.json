{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fsi-copilotgov/assessment/manifest/content-graph.schema.json",
  "title": "FSI-CopilotGov Content Graph",
  "description": "Canonical inventory of controls, playbooks, and solutions derived from the documentation tree. Generated by scripts/build_content_graph.py.",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "counts", "controls", "playbooks", "solutions"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "counts": {
      "type": "object",
      "required": [
        "controls",
        "pillars",
        "playbooks_total",
        "playbooks_control",
        "playbooks_cross_cutting",
        "solutions"
      ],
      "additionalProperties": false,
      "properties": {
        "controls": {"type": "integer", "minimum": 0},
        "pillars": {"type": "integer", "minimum": 0},
        "playbooks_total": {"type": "integer", "minimum": 0},
        "playbooks_control": {"type": "integer", "minimum": 0},
        "playbooks_cross_cutting": {"type": "integer", "minimum": 0},
        "solutions": {"type": "integer", "minimum": 0}
      }
    },
    "controls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "pillar", "title", "path", "regulatory_references"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+$"},
          "pillar": {"type": "integer", "minimum": 1, "maximum": 4},
          "title": {"type": "string"},
          "path": {"type": "string"},
          "last_verified": {
            "type": ["string", "null"],
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "regulatory_references": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "playbooks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "type"],
        "additionalProperties": false,
        "properties": {
          "path": {"type": "string"},
          "type": {"type": "string", "enum": ["control-implementation", "cross-cutting"]},
          "control_refs": {
            "type": "array",
            "items": {"type": "string"}
          },
          "category": {"type": "string"}
        },
        "allOf": [
          {
            "if": {"properties": {"type": {"const": "control-implementation"}}},
            "then": {"required": ["control_refs"]}
          },
          {
            "if": {"properties": {"type": {"const": "cross-cutting"}}},
            "then": {"required": ["category"]}
          }
        ]
      }
    },
    "solutions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "version", "control_coverage"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "version": {"type": "string"},
          "control_coverage": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    }
  }
}
